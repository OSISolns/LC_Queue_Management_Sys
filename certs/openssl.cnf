[req]
default_bits        = 4096
prompt              = no
default_md          = sha256
distinguished_name  = dn
x509_extensions     = v3_req

[dn]
C  = RW
ST = Kigali
L  = Kigali
O  = Legacy Clinics
CN = cs.legacyclinics.local

[v3_req]
subjectAltName      = @alt_names
basicConstraints    = CA:FALSE
keyUsage            = digitalSignature, keyEncipherment
extendedKeyUsage    = serverAuth

[alt_names]
DNS.1 = localhost
DNS.2 = cs.legacyclinics.local
DNS.3 = qs.legacyclinics.local
DNS.4 = nursing.legacyclinics.local
DNS.5 = *.legacyclinics.local
IP.1  = 127.0.0.1
