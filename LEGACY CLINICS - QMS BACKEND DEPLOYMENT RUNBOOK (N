sudo systemctl status qmsapp --no-pager

# Uvicorn logs:
sudo tail -n 200 /var/log/qmsapp/app.log
sudo tail -n 200 /var/log/qmsapp/error.log

# Nginx logs:
sudo tail -n 200 /var/log/nginx/access.log
sudo tail -n 200 /var/log/nginx/error.log

# Endpoint test:
curl -s https://qms.legacyclinics.dev/

