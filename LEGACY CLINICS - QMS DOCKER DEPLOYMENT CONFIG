3) DOCKERFILE (place at PROJECT ROOT: Dockerfile)
============================================================
FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates \
 && rm -rf /var/lib/apt/lists/*

# Non-root user
RUN useradd -m -u 10001 appuser

WORKDIR /app

# Install deps first (cache-friendly)
COPY backend/requirements.txt /app/backend/requirements.txt
RUN pip install --no-cache-dir -r /app/backend/requirements.txt

# Copy backend package (includes templates + static)
COPY backend /app/backend

# Make package importable
ENV PYTHONPATH=/app
ENV HOST=0.0.0.0
ENV PORT=8000
ENV WORKERS=2

EXPOSE 8000

# Healthcheck (requires /health route)
HEALTHCHECK --interval=30s --timeout=3s --start-period=20s --retries=3 \
  CMD curl -fsS http://127.0.0.1:8000/health || exit 1

USER appuser

# IMPORTANT:
# Your app defines `socket_app = socketio.ASGIApp(sio, app)`
# So we run socket_app so WebSockets work.
CMD ["sh", "-c", "uvicorn backend.main:socket_app --host ${HOST} --port ${PORT} --workers ${WORKERS}"]

============================================================
4) DOCKER COMPOSE (place at: deploy/docker-compose.yml)
============================================================
services:
  db:
    image: postgres:16-alpine
    container_name: qms_db
    restart: unless-stopped
    environment:
      POSTGRES_DB: qmsdb
      POSTGRES_USER: qmsuser
      POSTGRES_PASSWORD: CHANGE_ME_DB_PASSWORD
    volumes:
      - qms_db_data:/var/lib/postgresql/data
    networks:
      - qms_net

  api:
    build:
      context: ..
      dockerfile: ../Dockerfile
    container_name: qms_api
    restart: unless-stopped
    env_file:
      - ./env/qms.env
    depends_on:
      - db
    expose:
      - "8000"
    networks:
      - qms_net

  nginx:
    image: nginx:1.27-alpine
    container_name: qms_nginx
    restart: unless-stopped
    depends_on:
      - api
    ports:
      - "80:80"
      # For HTTPS you can do host-level certbot, or add 443 later.
    volumes:
      - ./nginx/qms.conf:/etc/nginx/conf.d/default.conf:ro
      - ../frontend/dist:/usr/share/nginx/html:ro
    networks:
      - qms_net

networks:
  qms_net:
    driver: bridge

volumes:
  qms_db_data:

============================================================
5) NGINX CONFIG (place at: deploy/nginx/qms.conf)
============================================================
server {
  listen 80;
  server_name qms.legacyclinics.dev;

  # Serve frontend (Vite dist)
  root /usr/share/nginx/html;
  index index.html;

  # Frontend routes (SPA fallback)
  location / {
    try_files $uri $uri/ /index.html;
  }

  # API proxy (you can also use /api prefix to keep clean)
  location /api/ {
    rewrite ^/api/(.*)$ /$1 break;
    proxy_pass http://api:8000;
    proxy_http_version 1.1;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    proxy_read_timeout 120;
    proxy_connect_timeout 10;
  }

  # Socket.IO (WebSockets)
  location /socket.io/ {
    proxy_pass http://api:8000/socket.io/;
    proxy_http_version 1.1;

    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    proxy_read_timeout 120;
    proxy_connect_timeout 10;
  }
}

